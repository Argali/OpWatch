# Copy this to .env.local for local development (optional, defaults work out of the box)
# VITE_API_URL=http://localhost:3001/api

# For GitHub Actions build — set as a repository secret:
# VITE_API_URL=https://your-backend.onrender.com/api

# OpenWeatherMap API key — required for the weather overlay (temp/rain/wind layers).
# Get a free key at https://openweathermap.org/api
# VITE_OWM_API_KEY=your_key_here
